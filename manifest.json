{
  "name": "Inkflow",
  "short_name": "Inkflow",
  "description": "Pipeline e tracker per progetti fumetto",
  "start_url": "./index.html",
  "display": "standalone",
  "background_color": "#1a1814",
  "theme_color": "#1a1814",
  "orientation": "portrait-primary",
  "icons": [
    {
      "src": "icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "share_target": {
    "action": "./share-target.html",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        { "name": "images", "accept": ["image/*"] }
      ]
    }
  }
}
